# 脑力锻炼应用 - 环境变量示例
# 复制此文件为 .env 并填写实际值

# ============= MySQL 数据库配置 =============
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=brain_training

# ============= Redis 配置 =============
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============= JWT 认证配置 =============
# 生产环境必须修改为复杂的随机字符串
SECRET_KEY=your-super-secret-key-change-in-production-must-be-long-and-random
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ============= 应用配置 =============
DEBUG=false
APP_NAME=脑力锻炼 API
APP_VERSION=1.0.0

# ============= CORS 配置 =============
# 允许的前端域名，多个用逗号分隔
# 生产环境应修改为实际域名
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5173
